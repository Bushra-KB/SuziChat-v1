POSTGRES_PORT=5433
POSTGRES_DB=suzi_chat
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Caddy site address (no scheme). Required for infra/caddy/Caddyfile.
SUZI_DOMAIN=your-domain.com

# API (interpolated into compose `environment:` for the api service)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
CORS_ORIGINS=https://your-domain.com
APP_BASE_URL=https://your-domain.com
EMAIL_VERIFICATION_TTL_MINUTES=1440
UPLOADS_DIR=/app/uploads
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
MAIL_FROM=Suzi Chat <no-reply@your-domain.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Optional web build/runtime
NEXT_PUBLIC_API_BASE_URL=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ExoClick ads (web build). Set NEXT_PUBLIC_ADS_ENABLED=true and the Zone IDs
# from the ExoClick publisher dashboard, then redeploy (these are inlined at
# build time). Leave blank / false to keep ads off. Never store the ExoClick
# account credentials here — only Zone IDs.
NEXT_PUBLIC_ADS_ENABLED=false
# Small anchored bottom bar (use a 320x50 ExoClick zone).
NEXT_PUBLIC_EXOCLICK_ZONE_STICKY=
NEXT_PUBLIC_EXOCLICK_ZONE_REELS=
NEXT_PUBLIC_EXOCLICK_ZONE_SNAPS=
NEXT_PUBLIC_EXOCLICK_ZONE_DATING=

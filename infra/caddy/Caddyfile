{$SUZI_DOMAIN} {
  encode zstd gzip

  @api path /api/*
  handle @api {
    uri strip_prefix /api
    reverse_proxy api:4000
  }

  @socket path /socket.io/*
  handle @socket {
    reverse_proxy api:4000
  }

  @socketproxy path /api/socket.io/*
  handle @socketproxy {
    uri strip_prefix /api
    reverse_proxy api:4000
  }

  @livekit path /livekit*
  handle @livekit {
    uri strip_prefix /livekit
    reverse_proxy livekit:7880
  }

  handle {
    reverse_proxy web:3000
  }
}

# Redirect the www subdomain to the canonical apex domain.
# Caddy will auto-provision a TLS cert for this hostname on first request
# (DNS for www.* must already point to this server, which it does).
www.{$SUZI_DOMAIN} {
  redir https://{$SUZI_DOMAIN}{uri} permanent
}

# Shared
NODE_ENV=development
SUZI_DOMAIN=localhost

# Web
NEXT_PUBLIC_APP_NAME=Suzi Chat
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
# Google sign-in (web button)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# Sign in with Apple — web fallback only (native iOS uses the bundle id).
# Service ID configured in the Apple Developer portal + its return URL.
NEXT_PUBLIC_APPLE_SERVICE_ID=
NEXT_PUBLIC_APPLE_REDIRECT_URI=https://suzichat.com/login
# ExoClick ads. Master switch, then one Zone ID per placement (create the zones
# in the ExoClick dashboard). Empty Zone IDs render nothing. NEVER put the
# ExoClick account username/password here — only Zone IDs.
# For the mobile build these must be present when running `cap:sync`/`build:mobile`
# (e.g. in apps/web/.env.production) so Next can inline them into the static export.
NEXT_PUBLIC_ADS_ENABLED=false
# Small anchored bottom bar (use a 320x50 ExoClick zone).
NEXT_PUBLIC_EXOCLICK_ZONE_STICKY=
NEXT_PUBLIC_EXOCLICK_ZONE_REELS=
NEXT_PUBLIC_EXOCLICK_ZONE_SNAPS=
NEXT_PUBLIC_EXOCLICK_ZONE_DATING=

# API
PORT=4000
# If Postgres is mapped to another port (e.g. 5433 in Docker), set the same port here and in `pnpm db:push`.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/suzi_chat
JWT_ACCESS_SECRET=replace-with-strong-secret
JWT_REFRESH_SECRET=replace-with-strong-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
PASSWORD_RESET_TTL_MINUTES=30
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=1
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Auth providers / email
GOOGLE_CLIENT_ID=
# Sign in with Apple (Guideline 4.8): comma-separated allowed audiences —
# iOS bundle id and/or web Service ID.
APPLE_CLIENT_IDS=com.suzichat.app
EMAIL_VERIFICATION_TTL_MINUTES=1440
# SMTP — REQUIRED for verification + password-reset emails to send.
MAIL_FROM=Suzi Chat <no-reply@suzichat.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Storage
UPLOAD_DIR=./uploads

# WebRTC calls (audio/video). STUN works out of the box; TURN is required for
# reliable connections across NAT/firewalls. Leave TURN_* blank to use STUN only.
STUN_URLS=stun:stun.l.google.com:19302
TURN_URLS=
TURN_SECRET=
TURN_REALM=suzichat.com
TURN_TTL_SECONDS=3600
# Public IP of the server running coturn (prod only).
TURN_EXTERNAL_IP=
# Max participants in a room audio call.
ROOM_CALL_MAX=6

# ChatRoom Live broadcast (LiveKit SFU).
# Local default: run `docker compose -f infra/docker/docker-compose.local.yml --profile live up -d livekit`
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=suzi_livekit_dev
LIVEKIT_API_SECRET=local-dev-livekit-secret
LIVEKIT_NODE_IP=127.0.0.1

# Shared
NODE_ENV=development

# Web
NEXT_PUBLIC_APP_NAME=Suzi Chat
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# API
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/suzi_chat
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Storage
UPLOAD_DIR=./uploads

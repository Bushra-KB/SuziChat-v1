generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELED
}

enum PostKind {
  SNAP
  REEL
}

enum RoomJoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

enum DatingSwipeAction {
  LIKE
  PASS
}

enum GameType {
  CHESS
  CHECKERS
  CONNECT4
  POKER_HOLDEM
}

enum GameLobbyStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum GameSessionStatus {
  WAITING
  ACTIVE
  FINISHED
  CANCELED
}

enum GameSeatStatus {
  OPEN
  RESERVED
  OCCUPIED
  FOLDED
  ELIMINATED
}

enum GameEventType {
  SYSTEM
  CHAT
  INVITE
  STATE
  ACTION
  ERROR
}

enum MoveKind {
  MOVE
  RESIGN
  DRAW_OFFER
  DRAW_ACCEPT
  TIMEOUT
  POKER_ACTION
}

enum PokerRound {
  PREFLOP
  FLOP
  TURN
  RIVER
  SHOWDOWN
  COMPLETE
}

enum PokerActionKind {
  FOLD
  CHECK
  CALL
  BET
  RAISE
  ALL_IN
  POST_SMALL_BLIND
  POST_BIG_BLIND
}

model User {
  id                        String    @id @default(cuid())
  email                     String    @unique
  username                  String    @unique
  displayName               String?
  avatarUrl                 String?
  bio                       String?
  country                   String?
  passwordHash              String
  refreshTokenHash          String?
  passwordResetTokenHash    String?
  passwordResetTokenExpiresAt DateTime?
  sentFriendRequests        FriendRequest[]   @relation("FriendRequestSender")
  receivedFriendRequests    FriendRequest[]   @relation("FriendRequestReceiver")
  friendships               Friendship[]      @relation("FriendshipUser")
  friendOf                  Friendship[]      @relation("FriendshipFriend")
  role                      UserRole  @default(USER)
  isAdultConfirmed          Boolean   @default(false)
  isEmailVerified           Boolean   @default(false)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  roomsOwned                Room[]    @relation("RoomsOwned")
  roomMemberships           RoomMembership[]
  roomJoinRequests          RoomJoinRequest[]
  roomBans                  RoomBan[]
  roomMessages              RoomMessage[] @relation("RoomMessagesSent")
  dmsSent                   DirectMessage[] @relation("DmSent")
  dmsReceived               DirectMessage[] @relation("DmRecv")
  posts                     Post[]    @relation("PostsAuthored")
  postLikes                 PostLike[]
  postComments              PostComment[]
  postViews                 PostView[]
  notifications             Notification[] @relation("UserNotifications")
  blockedUsers             UserBlock[] @relation("UserBlocksSent")
  blockedByUsers           UserBlock[] @relation("UserBlocksReceived")
  datingProfile            DatingProfile?
  datingSwipesFrom         DatingSwipe[] @relation("DatingSwipeFrom")
  datingSwipesTo           DatingSwipe[] @relation("DatingSwipeTo")
  datingMatchesA           DatingMatch[] @relation("DatingMatchUserA")
  datingMatchesB           DatingMatch[] @relation("DatingMatchUserB")
  datingMessagesSent       DatingMessage[] @relation("DatingMessageSender")
  ownedGameLobbies         GameLobby[] @relation("GameLobbyOwner")
  gameSeats                GameSeat[]
  gameSessionsTurn         GameSession[] @relation("GameSessionTurnUser")
  gameSessionsWon          GameSession[] @relation("GameSessionWinnerUser")
  gameMoves                GameMove[]
  gameEvents               GameEvent[]
  pokerActions             PokerAction[]
}

model GameLobby {
  id          String          @id @default(cuid())
  slug        String          @unique
  gameType    GameType
  title       String
  isPrivate   Boolean         @default(false)
  ownerId     String
  owner       User            @relation("GameLobbyOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  status      GameLobbyStatus @default(OPEN)
  maxSeats    Int             @default(2)
  settings    Json?
  seats       GameSeat[]
  sessions    GameSession[]
  events      GameEvent[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([gameType, status])
  @@index([ownerId, createdAt])
}

model GameSeat {
  id          String         @id @default(cuid())
  lobbyId     String
  lobby       GameLobby      @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  seatIndex   Int
  status      GameSeatStatus @default(OPEN)
  stackChips  Int            @default(0)
  joinedAt    DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([lobbyId, seatIndex])
  @@unique([lobbyId, userId])
  @@index([userId, updatedAt])
}

model GameSession {
  id           String            @id @default(cuid())
  lobbyId      String
  lobby        GameLobby         @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  gameType     GameType
  status       GameSessionStatus @default(WAITING)
  state        Json
  turnUserId   String?
  turnUser     User?             @relation("GameSessionTurnUser", fields: [turnUserId], references: [id], onDelete: SetNull)
  winnerUserId String?
  winnerUser   User?             @relation("GameSessionWinnerUser", fields: [winnerUserId], references: [id], onDelete: SetNull)
  startedAt    DateTime?
  endedAt      DateTime?
  moves        GameMove[]
  events       GameEvent[]
  pokerHand    PokerHandState?
  pokerActions PokerAction[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([lobbyId, createdAt])
  @@index([status, updatedAt])
}

model GameMove {
  id        String   @id @default(cuid())
  sessionId String
  session   GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      MoveKind @default(MOVE)
  ply       Int
  payload   Json
  createdAt DateTime @default(now())

  @@index([sessionId, createdAt])
  @@index([userId, createdAt])
}

model GameEvent {
  id        String      @id @default(cuid())
  lobbyId   String?
  lobby     GameLobby?  @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  sessionId String?
  session   GameSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  type      GameEventType
  payload   Json
  createdAt DateTime    @default(now())

  @@index([lobbyId, createdAt])
  @@index([sessionId, createdAt])
}

model PokerHandState {
  id                    String     @id @default(cuid())
  sessionId             String     @unique
  session               GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  dealerSeatIndex       Int
  smallBlindSeatIndex   Int
  bigBlindSeatIndex     Int
  pot                   Int        @default(0)
  communityCards        Json
  round                 PokerRound @default(PREFLOP)
  currentBet            Int        @default(0)
  minRaise              Int        @default(0)
  actionSeatIndex       Int
  lastAggressorSeatIndex Int?
  actions               PokerAction[]
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
}

model PokerAction {
  id          String          @id @default(cuid())
  handStateId String
  handState   PokerHandState  @relation(fields: [handStateId], references: [id], onDelete: Cascade)
  sessionId   String
  session     GameSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  seatIndex   Int
  kind        PokerActionKind
  amount      Int             @default(0)
  contribution Int            @default(0)
  isAllIn     Boolean         @default(false)
  createdAt   DateTime        @default(now())

  @@index([handStateId, createdAt])
  @@index([sessionId, createdAt])
}

model DatingProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  age            Int?
  gender         String?
  headline       String?
  datingBio      String?
  interests      Json?
  photoUrl       String?
  minAgePref     Int      @default(18)
  maxAgePref     Int      @default(99)
  seekGender     String   @default("any")
  isDiscoverable Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isDiscoverable, updatedAt])
}

model DatingSwipe {
  id         String            @id @default(cuid())
  fromUserId String
  toUserId   String
  action     DatingSwipeAction
  createdAt  DateTime          @default(now())
  fromUser   User              @relation("DatingSwipeFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser     User              @relation("DatingSwipeTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@index([toUserId, action])
}

model DatingMatch {
  id        String          @id @default(cuid())
  userAId   String
  userBId   String
  userA     User            @relation("DatingMatchUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB     User            @relation("DatingMatchUserB", fields: [userBId], references: [id], onDelete: Cascade)
  messages  DatingMessage[]
  createdAt DateTime        @default(now())

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

model DatingMessage {
  id        String      @id @default(cuid())
  matchId   String
  senderId  String
  body      String
  match     DatingMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  sender    User        @relation("DatingMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@index([matchId, createdAt])
}

model FriendRequest {
  id         String              @id @default(cuid())
  senderId   String
  receiverId String
  status     FriendRequestStatus @default(PENDING)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  sender     User                @relation("FriendRequestSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User                @relation("FriendRequestReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
}

model Friendship {
  id        String   @id @default(cuid())
  userId    String
  friendId  String
  createdAt DateTime @default(now())
  user      User     @relation("FriendshipUser", fields: [userId], references: [id], onDelete: Cascade)
  friend    User     @relation("FriendshipFriend", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
}

model UserBlock {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  blocker   User     @relation("UserBlocksSent", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("UserBlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
}

model Room {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  imageUrl    String?
  category    String   @default("Social")
  privacy     String   @default("Public")
  ownerId     String
  owner       User     @relation("RoomsOwned", fields: [ownerId], references: [id], onDelete: Cascade)
  messages    RoomMessage[]
  memberships RoomMembership[]
  joinRequests RoomJoinRequest[]
  bans        RoomBan[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RoomMembership {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  role      String   @default("member")
  joinedAt  DateTime @default(now())
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([userId])
}

model RoomJoinRequest {
  id         String                @id @default(cuid())
  roomId     String
  userId     String
  status     RoomJoinRequestStatus @default(PENDING)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  room       Room                  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user       User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([userId, status])
}

model RoomBan {
  id         String   @id @default(cuid())
  roomId     String
  userId     String
  reason     String?
  createdAt  DateTime @default(now())
  room       Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([userId])
}

model RoomMessage {
  id        String   @id @default(cuid())
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation("RoomMessagesSent", fields: [senderId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())

  @@index([roomId])
}

model DirectMessage {
  id          String   @id @default(cuid())
  senderId    String
  recipientId String
  sender      User     @relation("DmSent", fields: [senderId], references: [id], onDelete: Cascade)
  recipient   User     @relation("DmRecv", fields: [recipientId], references: [id], onDelete: Cascade)
  body        String
  createdAt   DateTime @default(now())

  @@index([senderId, recipientId])
}

model Post {
  id         String   @id @default(cuid())
  kind       PostKind
  authorId   String
  author     User     @relation("PostsAuthored", fields: [authorId], references: [id], onDelete: Cascade)
  mediaUrl   String
  title      String?
  caption    String?
  visibility String   @default("Public")
  likes      PostLike[]
  comments   PostComment[]
  views      PostView[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([kind, createdAt])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([userId, createdAt])
}

model PostComment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  body      String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId, createdAt])
  @@index([userId, createdAt])
}

model PostView {
  id          String   @id @default(cuid())
  postId      String
  userId      String
  viewedAt    DateTime @default(now())
  lastViewedAt DateTime @default(now())
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId, viewedAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}

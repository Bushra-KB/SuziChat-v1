{
  "name": "suzi-chat-v1",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev:api": "pnpm --filter api start:dev",
    "dev:web": "pnpm --filter web dev",
    "start:dev": "pnpm --filter api start:dev",
    "prisma:generate": "pnpm --filter api prisma:generate",
    "db:push": "pnpm --filter api db:push",
    "db:up": "docker compose -f infra/docker/docker-compose.local.yml --env-file infra/docker/.env.example up -d",
    "db:down": "docker compose -f infra/docker/docker-compose.local.yml down",
    "db:studio": "pnpm --filter api studio",
    "build:api": "pnpm --filter api build",
    "build:web": "pnpm --filter web build"
  }
}
